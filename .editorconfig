root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.php]
indent_style = space
indent_size = 4

[*.{js,css,html,json,yml,yaml,xml,md}]
indent_style = space
indent_size = 2

[*.{bat,ps1,sh}]
indent_style = space
indent_size = 2
end_of_line = crlf

[Makefile]
indent_style = tab

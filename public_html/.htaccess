<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    Options -MultiViews -Indexes

    # Hassas dosya ve klasorler public web'den okunamaz.
    RewriteRule ^(?:app|scripts|logs|backups|backup|vendor|storage|tmp)(?:/|$) - [F,L]
    RewriteRule ^(?:\.env|composer\.(?:json|lock)|package(?:-lock)?\.json|docker-compose\.ya?ml|Dockerfile|.*\.(?:sql|sqlite|bak|backup|log|ini|conf|sh|ps1))$ - [F,L]

    # robots.txt: route dynamically
    RewriteRule ^robots\.txt$ index.php?url=robots.txt [L,QSA]

    # sitemap.xml: Statik dosya varsa doğrudan sun, yoksa PHP üretsin
    RewriteCond %{HTTP_HOST} ^notlar\. [NC]
    RewriteCond %{DOCUMENT_ROOT}/sitemap_notes.xml -f
    RewriteRule ^sitemap\.xml$ sitemap_notes.xml [L]

    RewriteCond %{HTTP_HOST} !^notlar\. [NC]
    RewriteCond %{DOCUMENT_ROOT}/sitemap.xml -f
    RewriteRule ^sitemap\.xml$ sitemap.xml [L]

    # sitemap_main.xml / sitemap_notes.xml: statik varsa sun, yoksa PHP üretsin
    RewriteCond %{DOCUMENT_ROOT}/sitemap_main.xml -f
    RewriteRule ^sitemap_main\.xml$ sitemap_main.xml [L]

    RewriteCond %{DOCUMENT_ROOT}/sitemap_notes.xml -f
    RewriteRule ^sitemap_notes\.xml$ sitemap_notes.xml [L]

    RewriteCond %{DOCUMENT_ROOT}/sitemap_anonymity.xml -f
    RewriteRule ^sitemap_anonymity\.xml$ sitemap_anonymity.xml [L]

    # Kök ikon yolları: bazı crawler'lar HTML'i okumadan bu standart dosyaları dener.
    RewriteRule ^favicon\.ico$ cdn/light-favicon.ico [L]
    RewriteRule ^favicon-32x32\.png$ cdn/light-favicon-32x32.png [L]
    RewriteRule ^favicon-16x16\.png$ cdn/light-favicon-16x16.png [L]
    RewriteRule ^apple-touch-icon\.png$ cdn/light-apple-touch-icon.png [L]
    RewriteRule ^android-chrome-192x192\.png$ cdn/light-android-chrome-192x192.png [L]
    RewriteRule ^android-chrome-512x512\.png$ cdn/light-android-chrome-512x512.png [L]

    # Route all requests under /anonymitycheck/ to public_html/anonymitycheck/index.php
    RewriteRule ^anonymitycheck(?:/(.*))?$ anonymitycheck/index.php [L,QSA]

    # SEO friendly URL'ler
    RewriteRule ^privacy$ index.php?url=privacy [L,QSA]
    RewriteRule ^gizlilik-politikasi$ index.php?url=privacy [L,QSA,R=301]
    RewriteRule ^yazar/([a-zA-Z0-9_-]+)$ index.php?url=yazar/index/$1 [L,QSA]
    RewriteRule ^makale/([a-zA-Z0-9_-]+)$ index.php?url=makale/index/$1 [L,QSA]

    # Lang-prefixed static page shortcuts — explicit routes prevent hosting-level interference
    RewriteRule ^(tr|en)/hakkinda$ index.php?url=$1/hakkinda [L,QSA]
    RewriteRule ^(tr|en)/about$ index.php?url=$1/about [L,QSA]
    RewriteRule ^(tr|en)/manifesto$ index.php?url=$1/manifesto [L,QSA]
    RewriteRule ^(tr|en)/donate$ index.php?url=$1/donate [L,QSA]
    RewriteRule ^(tr|en)/bagis$ index.php?url=$1/bagis [L,QSA]
    RewriteRule ^(tr|en)/teyit$ index.php?url=$1/teyit [L,QSA]
    RewriteRule ^(tr|en)/verification$ index.php?url=$1/verification [L,QSA]
    RewriteRule ^(tr|en)/privacy$ index.php?url=$1/privacy [L,QSA]
    RewriteRule ^(tr|en)/gizlilik-politikasi$ index.php?url=$1/gizlilik-politikasi [L,QSA]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json application/xml
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject application/x-font-ttf application/x-font-opentype application/x-font-woff
    AddOutputFilterByType DEFLATE image/svg+xml image/x-icon

    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    
    ExpiresDefault "access plus 1 month"

    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/x-font-woff "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"

    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # sw.js must be re-fetched frequently so browser/CDN pick up service worker updates
    <Files "sw.js">
        Header set Cache-Control "max-age=3600, public"
    </Files>
    <FilesMatch "\.(js|css|gz)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    <FilesMatch "\.(ico|jpe?g|png|gif|swf|webp|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    # Sitemap & robots: kısa cache — Google taze sürümü görsün
    <FilesMatch "\.(xml|txt)$">
        Header set Cache-Control "max-age=600, public"
    </FilesMatch>
    <FilesMatch "\.(php|html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
    Header always set Vary "Accept-Encoding"
</IfModule>

<IfModule mod_headers.c>
    # Font dosyaları için CORS izni ver
    <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|font.css)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

AddType application/javascript .mjs
AddType application/manifest+json .webmanifest

# PHP Ayarlari — Apache mod_php kullanan sunucular icin. 
# LiteSpeed (LSPHP) ve PHP-FPM sunucular bu blogu es gecer ve dizindeki .user.ini dosyasini okur.
# Bu sayede LiteSpeed sunucularda 500 Internal Server Error alinmasi engellenir.
<IfModule mod_php.c>
    php_value session.save_handler files
    php_value session.save_path "/home/fezadano5/tmp/sessions"
    php_value session.use_strict_mode 1
    php_value session.gc_maxlifetime 1440
    php_value upload_max_filesize 20M
    php_value post_max_size 25M
    php_value memory_limit 256M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value upload_tmp_dir "/home/fezadano5/tmp"
</IfModule>


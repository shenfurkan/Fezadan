{
  "name": "fezadan",
  "version": "1.0.0",
  "description": "Privacy-first, self-sufficient publishing platform — frontend tooling",
  "scripts": {
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "preflight": "node scripts/preflight.mjs",
    "dev": "npx @tailwindcss/cli -i ./public_html/assets/css/input.css -o ./public_html/assets/css/style.css --watch",
    "build": "npx @tailwindcss/cli -i ./public_html/assets/css/input.css -o ./public_html/assets/css/style.css --minify"
  },
  "keywords": ["cms", "publishing", "privacy", "blog", "php", "tailwindcss"],
  "author": "Fezadan Collective",
  "license": "GPL-3.0",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.0",
    "mammoth": "^1.12.0",
    "tailwindcss": "^4.3.0"
  }
}
